---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Cta { label: string; href: string }
interface Props {
  image: ImageMetadata;
  alt: string;
  kicker: string;
  heading: string;
  sub: string;
  primary?: Cta;
  secondary?: Cta;
  /** Smaller hero for interior pages */
  compact?: boolean;
}
const { image, alt, kicker, heading, sub, primary, secondary, compact = false } = Astro.props;
---

<section class:list={["hero", { "hero--compact": compact }]}>
  <div class="hero__media">
    <Image
      src={image}
      alt={alt}
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      format="avif"
    />
  </div>
  <div class="hero__scrim"></div>

  <div class="hero__inner container--wide">
    <div class="hero__content">
      <span class="hero__kicker kicker">{kicker}</span>
      <h1 class="hero__title" set:html={heading}></h1>
      <p class="hero__sub">{sub}</p>
      {(primary || secondary) && (
        <div class="hero__cta btn-row">
          {primary && <a href={primary.href} class="btn">{primary.label}</a>}
          {secondary && <a href={secondary.href} class="btn btn--outline">{secondary.label}</a>}
        </div>
      )}
    </div>
  </div>

  {!compact && <span class="scroll-cue" aria-hidden="true">Scroll</span>}
</section>

<style>
  .hero {
    position: relative;
    min-height: clamp(580px, 94svh, 920px);
    display: flex;
    align-items: flex-end;
    color: var(--cream);
    overflow: hidden;
    isolation: isolate;
  }
  .hero--compact { min-height: clamp(420px, 62svh, 600px); }

  .hero__media { position: absolute; inset: 0; z-index: -2; }
  .hero__media img { width: 100%; height: 100%; object-fit: cover; }

  .hero__scrim {
    position: absolute; inset: 0; z-index: -1;
    background:
      linear-gradient(180deg, rgba(20,16,10,0.52) 0%, rgba(20,16,10,0.10) 24%, rgba(20,16,10,0.60) 80%, rgba(20,16,10,0.88) 100%),
      linear-gradient(90deg, rgba(20,16,10,0.58) 0%, rgba(20,16,10,0.12) 52%, transparent 80%);
  }

  .hero__inner { width: 100%; padding-block: var(--space-2xl) var(--space-xl); }
  .hero__content { max-width: 40rem; }
  .hero__kicker { color: var(--ochre); }
  .hero__title {
    color: var(--cream);
    font-size: var(--step-5);
    margin: 0.5rem 0 1rem;
    text-shadow: 0 2px 30px rgba(0,0,0,0.35);
  }
  .hero__sub {
    font-size: var(--step-1);
    line-height: var(--leading-snug);
    color: color-mix(in srgb, var(--cream) 92%, transparent);
    max-width: 32rem;
    margin-bottom: var(--space-md);
  }
  .hero__cta { gap: var(--space-xs); }

  .scroll-cue {
    position: absolute; bottom: 1.4rem; left: 50%; transform: translateX(-50%);
    font-family: var(--font-body); font-weight: 700; font-size: 0.62rem;
    letter-spacing: var(--tracking-wider); text-transform: uppercase;
    color: color-mix(in srgb, var(--cream) 80%, transparent);
  }
  .scroll-cue::after { content: ""; display: block; width: 1px; height: 26px; margin: 0.5rem auto 0; background: currentColor; opacity: 0.7; }
</style>
