---
import { Image, getImage } from "astro:assets";
import type { GalleryItem } from "../data/gallery";

interface Tab { id: string; label: string; intro?: string; items: GalleryItem[] }
interface Props { tabs: Tab[] }
const { tabs } = Astro.props;

// Pre-generate a large variant per image for the lightbox.
const tabsData = await Promise.all(
  tabs.map(async (t) => ({
    ...t,
    items: await Promise.all(
      t.items.map(async (it) => ({
        ...it,
        full: (await getImage({ src: it.src, width: 1600, format: "avif" })).src,
      }))
    ),
  }))
);
---

<div class="gallery">
  <div class="tablist" role="tablist" aria-label="Gallery categories">
    {tabsData.map((t, i) => (
      <button
        role="tab"
        id={`tab-${t.id}`}
        aria-controls={`panel-${t.id}`}
        aria-selected={i === 0 ? "true" : "false"}
        class:list={["tab", { "is-active": i === 0 }]}
        data-tab={t.id}
      >{t.label}</button>
    ))}
  </div>

  {tabsData.map((t, i) => (
    <section
      id={`panel-${t.id}`}
      role="tabpanel"
      aria-labelledby={`tab-${t.id}`}
      class="panel"
      data-panel-id={t.id}
      hidden={i !== 0}
    >
      {t.intro && <p class="panel__intro lede">{t.intro}</p>}
      <div class="masonry">
        {t.items.map((it, idx) => (
          <button
            class="tile"
            data-lb-item
            data-full={it.full}
            data-alt={it.alt}
            data-index={idx}
            aria-label={`View image: ${it.alt}`}
          >
            <Image src={it.src} alt={it.alt} widths={[400, 700, 900]} sizes="(min-width:1000px) 30vw, (min-width:600px) 45vw, 90vw" format="avif" loading="lazy" />
            <span class="tile__zoom" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.2-3.2M11 8v6M8 11h6"/></svg>
            </span>
          </button>
        ))}
      </div>
    </section>
  ))}
</div>

<!-- Lightbox -->
<div class="lightbox" data-lb-overlay hidden>
  <div class="lightbox__dialog" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="lightbox__btn lightbox__close" data-lb-close aria-label="Close viewer">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6 6 18"/></svg>
    </button>
    <button class="lightbox__btn lightbox__prev" data-lb-prev aria-label="Previous image">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 6l-6 6 6 6"/></svg>
    </button>
    <figure class="lightbox__figure">
      <img data-lb-img alt="" />
      <figcaption data-lb-cap class="lightbox__cap"></figcaption>
    </figure>
    <button class="lightbox__btn lightbox__next" data-lb-next aria-label="Next image">
      <svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 6l6 6-6 6"/></svg>
    </button>
  </div>
</div>

<style>
  .tablist { display: inline-flex; gap: 4px; padding: 5px; background: color-mix(in srgb, var(--bark) 12%, transparent); border-radius: 999px; margin-bottom: var(--space-md); }
  .tab {
    font-family: var(--font-body); font-weight: 700; font-size: var(--step--1);
    letter-spacing: 0.04em; text-transform: uppercase; padding: 0.6em 1.3em; border-radius: 999px;
    color: var(--ink-soft); transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }
  .tab.is-active { background: var(--ochre); color: var(--ink); }
  .panel[hidden] { display: none; }
  .panel__intro { max-width: 60ch; margin-bottom: var(--space-md); }

  .masonry { columns: 1; column-gap: var(--space-xs); }
  @media (min-width: 600px) { .masonry { columns: 2; } }
  @media (min-width: 1000px) { .masonry { columns: 3; } }
  .tile {
    position: relative; display: block; width: 100%; margin: 0 0 var(--space-xs);
    break-inside: avoid; border-radius: var(--radius); overflow: hidden; padding: 0; line-height: 0;
    background: var(--sand-2);
  }
  .tile :global(img) { width: 100%; height: auto; transition: transform var(--dur-slow) var(--ease); }
  .tile:hover :global(img), .tile:focus-visible :global(img) { transform: scale(1.05); }
  .tile__zoom {
    position: absolute; inset: 0; display: grid; place-items: center; color: var(--cream);
    background: linear-gradient(0deg, rgba(20,16,10,0.4), rgba(20,16,10,0.05));
    opacity: 0; transition: opacity var(--dur) var(--ease);
  }
  .tile:hover .tile__zoom, .tile:focus-visible .tile__zoom { opacity: 1; }
  @media (prefers-reduced-motion: reduce) { .tile:hover :global(img) { transform: none; } }

  /* Lightbox */
  .lightbox { position: fixed; inset: 0; z-index: var(--z-lightbox); display: grid; place-items: center;
    background: rgba(20,16,10,0.92); padding: clamp(0.5rem, 3vw, 2rem); }
  .lightbox[hidden] { display: none; }
  .lightbox__dialog { position: relative; width: min(100%, 1200px); display: flex; align-items: center; justify-content: center; }
  .lightbox__figure { margin: 0; max-width: 100%; }
  .lightbox__figure img { max-width: 100%; max-height: 82svh; border-radius: var(--radius); box-shadow: var(--shadow-lg); }
  .lightbox__cap { color: color-mix(in srgb, var(--cream) 82%, transparent); text-align: center; margin-top: 0.8rem; font-size: var(--step--1); }
  .lightbox__btn { position: absolute; display: grid; place-items: center; width: 48px; height: 48px; border-radius: 999px;
    background: color-mix(in srgb, var(--cream) 14%, transparent); color: var(--cream); backdrop-filter: blur(4px);
    transition: background var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease); }
  .lightbox__btn:hover { background: var(--ochre); color: var(--ink); }
  .lightbox__close { top: -6px; right: -6px; }
  .lightbox__prev { left: -6px; }
  .lightbox__next { right: -6px; }
  @media (min-width: 720px) { .lightbox__prev { left: -64px; } .lightbox__next { right: -64px; } .lightbox__close { top: -56px; right: 0; } }
  @media (prefers-reduced-motion: no-preference) { .lightbox:not([hidden]) .lightbox__figure img { animation: lbpop var(--dur) var(--ease-out); } }
  @keyframes lbpop { from { opacity: 0; transform: scale(0.97); } to { opacity: 1; transform: none; } }
</style>

<script>
  function initGallery() {
    // Tabs
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>(".tab[data-tab]"));
    const panels = Array.from(document.querySelectorAll<HTMLElement>(".panel[data-panel-id]"));
    function selectTab(id: string) {
      tabs.forEach((t) => {
        const active = t.dataset.tab === id;
        t.setAttribute("aria-selected", String(active));
        t.classList.toggle("is-active", active);
      });
      panels.forEach((p) => (p.hidden = p.dataset.panelId !== id));
    }
    tabs.forEach((t, i) => {
      t.addEventListener("click", () => selectTab(t.dataset.tab!));
      t.addEventListener("keydown", (e) => {
        if (e.key !== "ArrowRight" && e.key !== "ArrowLeft") return;
        e.preventDefault();
        const dir = e.key === "ArrowRight" ? 1 : -1;
        const next = tabs[(i + dir + tabs.length) % tabs.length];
        next.focus();
        selectTab(next.dataset.tab!);
      });
    });

    // Lightbox
    const overlay = document.querySelector<HTMLElement>("[data-lb-overlay]");
    const img = document.querySelector<HTMLImageElement>("[data-lb-img]");
    const cap = document.querySelector<HTMLElement>("[data-lb-cap]");
    if (!overlay || !img || !cap) return;
    let list: { full: string; alt: string }[] = [];
    let index = 0;
    let lastFocus: HTMLElement | null = null;

    function render() {
      const item = list[index];
      img!.src = item.full;
      img!.alt = item.alt;
      cap!.textContent = item.alt;
    }
    function open(panel: HTMLElement, i: number) {
      list = Array.from(panel.querySelectorAll<HTMLElement>("[data-lb-item]")).map((b) => ({
        full: b.dataset.full!, alt: b.dataset.alt!,
      }));
      index = i;
      lastFocus = document.activeElement as HTMLElement;
      overlay!.hidden = false;
      document.body.style.overflow = "hidden";
      render();
      (overlay!.querySelector("[data-lb-close]") as HTMLElement)?.focus();
    }
    function close() {
      overlay!.hidden = true;
      document.body.style.overflow = "";
      lastFocus?.focus();
    }
    const step = (d: number) => { index = (index + d + list.length) % list.length; render(); };

    document.querySelectorAll<HTMLElement>("[data-lb-item]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const panel = btn.closest<HTMLElement>(".panel");
        if (panel) open(panel, Number(btn.dataset.index));
      });
    });
    overlay.querySelector("[data-lb-close]")?.addEventListener("click", close);
    overlay.querySelector("[data-lb-prev]")?.addEventListener("click", () => step(-1));
    overlay.querySelector("[data-lb-next]")?.addEventListener("click", () => step(1));
    overlay.addEventListener("click", (e) => { if (e.target === overlay) close(); });
    document.addEventListener("keydown", (e) => {
      if (overlay.hidden) return;
      if (e.key === "Escape") close();
      else if (e.key === "ArrowLeft") step(-1);
      else if (e.key === "ArrowRight") step(1);
      else if (e.key === "Tab") {
        // simple focus trap among the visible controls
        const focusable = Array.from(overlay.querySelectorAll<HTMLElement>("button"));
        const first = focusable[0], last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    });
  }
  document.addEventListener("astro:page-load", initGallery);
</script>
