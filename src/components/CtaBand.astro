---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Cta { label: string; href: string }
interface Props {
  kicker?: string;
  heading: string;
  text?: string;
  primary: Cta;
  secondary?: Cta;
  image?: ImageMetadata;
  alt?: string;
}
const { kicker, heading, text, primary, secondary, image, alt = "" } = Astro.props;
---
<section class="cta-band on-dark" data-reveal>
  {image && (
    <div class="cta-band__media">
      <Image src={image} alt={alt} widths={[768, 1280, 1920]} sizes="100vw" format="avif" loading="lazy" />
      <div class="cta-band__scrim"></div>
    </div>
  )}
  <div class="container--narrow cta-band__inner text-center">
    {kicker && <span class="kicker">{kicker}</span>}
    <h2>{heading}</h2>
    {text && <p class="lede" style="color: color-mix(in srgb, var(--cream) 88%, transparent); margin-inline:auto; max-width: 46ch;">{text}</p>}
    <div class="btn-row" style="justify-content:center; margin-top: var(--space-sm);">
      <a href={primary.href} class="btn">{primary.label}</a>
      {secondary && <a href={secondary.href} class="btn btn--outline">{secondary.label}</a>}
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative; isolation: isolate;
    background: var(--bushveld-deep);
    padding-block: var(--space-2xl);
    overflow: hidden;
  }
  .cta-band__media { position: absolute; inset: 0; z-index: -2; }
  .cta-band__media :global(img) { width: 100%; height: 100%; object-fit: cover; }
  .cta-band__scrim {
    position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(180deg, rgba(28,26,23,0.78), rgba(28,26,23,0.88));
  }
  .cta-band__inner > * + * { margin-top: var(--space-sm); }
  .cta-band h2 { font-size: var(--step-4); }
</style>
