---
import { NAV, SITE } from "../data/site";

interface Props {
  /** When true the header floats transparently over a hero until scrolled. */
  overHero?: boolean;
}
const { overHero = false } = Astro.props;
const path = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<header class:list={["site-header", { "site-header--over": overHero }]} data-header>
  <div class="site-header__inner container--wide">
    <a href="/" class="brand" aria-label={`${SITE.name} — home`}>
      <span class="brand__name">Caldwell</span>
      <span class="brand__sub">Safaris</span>
    </a>

    <nav class="nav-desktop" aria-label="Primary">
      <ul>
        {NAV.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={path === item.href ? "page" : undefined}
            >{item.label}</a>
          </li>
        ))}
      </ul>
      <a href="/contact" class="btn btn--green nav-cta">Plan Your Safari</a>
    </nav>

    <button class="nav-toggle" aria-label="Open menu" aria-expanded="false" data-nav-toggle>
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="nav-mobile" data-nav-drawer hidden>
    <nav aria-label="Mobile">
      <ul>
        {NAV.map((item) => (
          <li><a href={item.href} aria-current={path === item.href ? "page" : undefined}>{item.label}</a></li>
        ))}
      </ul>
      <a href="/contact" class="btn btn--green nav-mobile__cta">Plan Your Safari</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: var(--z-header);
    background: var(--sand);
    border-bottom: 1px solid var(--line);
    transition: background var(--dur) var(--ease), border-color var(--dur) var(--ease),
      box-shadow var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .site-header__inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: var(--space-md); min-height: 72px; padding-block: 0.6rem;
  }

  /* Transparent over hero */
  .site-header--over {
    position: fixed; inset: 0 0 auto 0; background: transparent; border-color: transparent; color: var(--cream);
  }
  .site-header--over .brand__name, .site-header--over .brand__sub { color: var(--cream); }
  .site-header--over.is-scrolled {
    position: fixed; background: color-mix(in srgb, var(--sand) 94%, transparent);
    backdrop-filter: blur(10px); border-color: var(--line); box-shadow: var(--shadow-sm);
    color: var(--ink);
  }
  .site-header--over.is-scrolled .brand__name { color: var(--ink); }
  .site-header--over.is-scrolled .brand__sub { color: var(--bark); }

  .brand { display: flex; align-items: baseline; gap: 0.4em; line-height: 1; }
  .brand__name { font-family: var(--font-display); font-size: 1.5rem; letter-spacing: 0.04em; color: var(--ink); }
  .brand__sub {
    font-family: var(--font-body); font-weight: 700; font-size: 0.7rem;
    text-transform: uppercase; letter-spacing: var(--tracking-wider); color: var(--bark);
  }

  .nav-desktop { display: none; align-items: center; gap: var(--space-md); }
  .nav-desktop ul { display: flex; gap: clamp(1rem, 2vw, 2rem); list-style: none; padding: 0; }
  .nav-desktop a {
    font-weight: 600; font-size: var(--step--1); letter-spacing: 0.04em; text-transform: uppercase;
    position: relative; padding-block: 0.5rem; color: inherit;
  }
  .nav-desktop a::after {
    content: ""; position: absolute; left: 0; bottom: 0; height: 2px; width: 0; background: var(--ochre);
    transition: width var(--dur) var(--ease);
  }
  .nav-desktop a:hover::after, .nav-desktop a[aria-current="page"]::after { width: 100%; }
  .nav-cta { padding: 0.7em 1.2em; }

  /* Toggle */
  .nav-toggle { display: grid; gap: 5px; padding: 10px; }
  .nav-toggle span { display: block; width: 26px; height: 2px; background: currentColor; transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease); }
  .nav-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile drawer */
  .nav-mobile {
    overflow: hidden; background: var(--sand); border-bottom: 1px solid var(--line);
  }
  .nav-mobile[hidden] { display: none; }
  .nav-mobile nav { padding: var(--space-sm) var(--gutter) var(--space-md); }
  .nav-mobile ul { list-style: none; padding: 0; display: grid; gap: 0.25rem; }
  .nav-mobile ul a {
    display: block; font-family: var(--font-display); font-size: 1.4rem; color: var(--ink);
    padding: 0.6rem 0; border-bottom: 1px solid var(--line);
  }
  .nav-mobile ul a[aria-current="page"] { color: var(--bark); }
  .nav-mobile__cta { margin-top: var(--space-sm); width: 100%; justify-content: center; }

  @media (prefers-reduced-motion: no-preference) {
    .nav-mobile[data-open] { animation: drawer var(--dur) var(--ease); }
  }
  @keyframes drawer { from { max-height: 0; opacity: 0; } to { max-height: 480px; opacity: 1; } }

  @media (min-width: 860px) {
    .nav-desktop { display: flex; }
    .nav-toggle, .nav-mobile { display: none; }
  }
</style>

<script>
  function initHeader() {
    const header = document.querySelector<HTMLElement>("[data-header]");
    const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
    const drawer = document.querySelector<HTMLElement>("[data-nav-drawer]");
    if (!header) return;

    // Scroll state (header solidifies; documentElement.scrolled hides the hero scroll cue)
    const onScroll = () => {
      const scrolled = window.scrollY > 24;
      header.classList.toggle("is-scrolled", scrolled);
      document.documentElement.classList.toggle("scrolled", scrolled);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });

    if (toggle && drawer) {
      const setOpen = (open: boolean) => {
        toggle.setAttribute("aria-expanded", String(open));
        toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        if (open) {
          drawer.hidden = false;
          drawer.setAttribute("data-open", "");
        } else {
          drawer.removeAttribute("data-open");
          drawer.hidden = true;
        }
      };
      toggle.addEventListener("click", () =>
        setOpen(toggle.getAttribute("aria-expanded") !== "true")
      );
      drawer.addEventListener("click", (e) => {
        if ((e.target as HTMLElement).tagName === "A") setOpen(false);
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setOpen(false);
      });
    }
  }
  document.addEventListener("astro:page-load", initHeader);
</script>
